{
  "name": "vidtoolkits",
  "version": "0.1.0",
  "private": true,
  "description": "Video creation toolkit — convert markdown scripts into videos with AI voice-over and free stock imagery",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:api": "pnpm --filter vidtoolkits-api dev",
    "dev:web": "pnpm --filter vidtoolkits-web dev",
    "dev:remotion": "pnpm --filter remotion dev",
    "build": "pnpm -r build",
    "build:api": "pnpm --filter vidtoolkits-api build",
    "build:web": "pnpm --filter vidtoolkits-web build",
    "build:remotion": "pnpm --filter remotion build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  }
}
