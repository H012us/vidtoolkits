# vidtoolkits environment configuration
# Copy this file to .env and fill in your values.
# All variables are OPTIONAL — the app works without API keys using fallback behavior.

# =============================================================================
# SERVER
# =============================================================================
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# =============================================================================
# IMAGE PROVIDER API KEYS (all optional — fallback chain handles missing keys)
# =============================================================================
# Pixabay: https://pixabay.com/api/docs/
# Free tier: ~5,000 requests/day
PIXABAY_API_KEY=

# Pexels: https://www.pexels.com/api/
# Free tier: 200 requests/hour
PEXELS_API_KEY=

# Unsplash: https://unsplash.com/developers
# Free tier: 50 requests/hour (demo), 5,000 requests/hour (approved)
UNSPLASH_ACCESS_KEY=

# =============================================================================
# VOICEOVER (TTS)
# =============================================================================
# Voicebox runs locally — see https://github.com/jamiepine/voicebox
# The app auto-detects if Voicebox is running at localhost:17493
# No API key needed for Voicebox (local-only)
VOICEBOX_URL=http://127.0.0.1:17493

# =============================================================================
# PERFORMANCE (tuning for your hardware: i7 10th gen / 16GB RAM)
# =============================================================================
# Node.js max heap size (MB)
NODE_MAX_OLD_SPACE_SIZE=4096

# Remotion Chromium concurrency (default: auto-detected)
REMOTION_CONCURRENCY=

# Disk cache max size (MB)
CACHE_DISK_MAX_MB=2048

# =============================================================================
# LIMITS
# =============================================================================
# Max markdown file upload size (KB)
MAX_MD_SIZE_KB=500
