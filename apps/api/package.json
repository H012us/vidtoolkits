{
  "name": "vidtoolkits-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node --max-old-space-size=4096 dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --exclude='src/__tests__/routes/**/*.test.ts'",
    "test:uat": "vitest run --config vitest.uat.config.ts",
    "lint": "eslint src --ext .ts --max-warnings 0",
    "clean": "rm -rf dist .turbo node_modules"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@remotion/renderer": "^4.0.0",
    "@vidtoolkits/shared": "workspace:*",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "edge-tts-node": "^1.0.0",
    "express": "^4.19.0",
    "express-rate-limit": "^7.2.0",
    "fluent-ffmpeg": "^2.1.2",
    "gray-matter": "^4.0.3",
    "helmet": "^7.1.0",
    "lru-cache": "^10.2.0",
    "multer": "^1.4.5-lts.1",
    "p-limit": "^5.0.0",
    "pino": "^8.19.0",
    "pino-pretty": "^10.3.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.0",
    "unist": "^0.0.1",
    "unist-util-visit": "^5.0.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.8",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}